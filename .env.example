# Backend
ALGOGYM_ENVIRONMENT=development
ALGOGYM_DATABASE_URL=sqlite:///./data/algogym.db
ALGOGYM_CHROMA_PATH=./data/chroma
ALGOGYM_UPLOAD_DIR=./data/uploads

# Local LLM via Ollama's OpenAI-compatible API
ALGOGYM_OPENAI_BASE_URL=http://localhost:11434/v1
ALGOGYM_OPENAI_API_KEY=ollama
ALGOGYM_LLM_MODEL=llama3.2
ALGOGYM_EMBEDDING_MODEL=nomic-embed-text

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
